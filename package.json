{
  "name": "aegis-mail",
  "version": "1.0.0",
  "description": "Chrome Extension for intelligent email categorization and security analysis",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --coverageReporters=text --coverageReporters=html",
    "test:verbose": "jest --verbose",
    "test:analyzer": "jest email-analyzer",
    "test:whitelist": "jest whitelist-manager",
    "test:ai": "jest ai-analyzer"
  },
  "keywords": ["chrome-extension", "email", "security", "gmail"],
  "author": "Aegis Mail Team",
  "license": "MIT",
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": ["**/__tests__/**/*.test.js"],
    "collectCoverageFrom": [
      "src/analysis/*.js",
      "!src/package*.json"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/__tests__/",
      "/src/platforms/",
      "/src/ui/",
      "/src/analytics/"
    ],
    "setupFilesAfterEnv": ["<rootDir>/__tests__/setup.js"],
    "verbose": false
  }
}
